# astro-blog 環境変数のサンプル
# このファイルをコピーして `.env.local` を作成し、値を埋めて利用する。
# `.env.local` は git で追跡されない（.gitignore 済み）。

# --- 環境判定 ---
# "production" のとき本番扱い（draft/予約投稿を非表示、robots.txt で Allow）。
# それ以外（"preview", "development", 未設定）は dev 扱い。
# Cloudflare Pages のビルド設定では Production 環境に PUBLIC_APP_ENV=production を設定する。
PUBLIC_APP_ENV=development

# --- サイト URL ---
# astro.config.ts の site に渡される。本番では本番ドメインを設定。
# dev では Cloudflare Pages のプレビュー URL または localhost を利用。
PUBLIC_SITE_URL=http://localhost:4321

# --- コンテンツルート ---
# 既定では `./content`（git submodule）を参照する。
# submodule を取得していないローカル開発では、サンプル等を指すよう上書き可能。
# 例: CONTENT_ROOT=./content-sample
# CONTENT_ROOT=./content

# --- 将来追加予定 ---
# content submodule の private repo を checkout する際に必要になる場合:
# CONTENT_PAT=<GitHub Personal Access Token>

# Cloudflare Pages デプロイ時に GitHub Actions から参照するシークレット:
# （これらは GitHub Actions secrets に登録し、ローカル .env.local には通常入れない）
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ACCOUNT_ID=...
