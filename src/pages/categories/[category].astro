---
/**
 * カテゴリ別記事一覧（F-07）。`getStaticPaths` で全カテゴリを静的生成する。
 *
 * ルール:
 * - `params` にはカテゴリ名そのものを渡す。URL エンコードは Astro が自動で行う
 * - 日本語カテゴリ（例: "技術"）もそのまま `params` に渡せる
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostListItem from "../../components/PostListItem.astro";
import { listAllCategories, listPostsByCategory } from "../../lib/queries";

export async function getStaticPaths() {
  const categories = await listAllCategories();
  return categories.map((cat) => ({
    params: { category: cat.name },
    props: { category: cat.name },
  }));
}

const { category } = Astro.props;
const posts = await listPostsByCategory(category);
---

<BaseLayout title={`Category: ${category}`} description={`"${category}" カテゴリの記事一覧`}>
  <section class="bg-bg-secondary py-10 border-b border-border">
    <div class="container-wide">
      <p class="text-sm text-text-muted mb-1">
        <a href="/categories/" class="text-accent underline hover:no-underline">Categories</a>
      </p>
      <h1 class="text-3xl font-bold mb-2">{category}</h1>
      <p class="text-sm text-text-secondary">{posts.length} 件の記事</p>
    </div>
  </section>

  <section class="container-wide py-10">
    {
      posts.length === 0 ? (
        <p class="text-text-muted">このカテゴリの記事はまだありません。</p>
      ) : (
        <div class="max-w-[45rem]">
          {posts.map((post) => <PostListItem post={post} headingLevel={2} showTags />)}
        </div>
      )
    }
  </section>
</BaseLayout>
