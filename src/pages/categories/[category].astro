---
/**
 * カテゴリ別記事一覧（F-07）— 1 ページ目。`getStaticPaths` で全カテゴリを静的生成する。
 *
 * 要件 (requirements.md §6.5):
 * - 1 ページ 10 件。2 ページ目以降は `/categories/[category]/page/[n]/`
 * - `<link rel="canonical">`, `<link rel="next">` を BaseLayout の props で出力
 *
 * ルール:
 * - `params` にはカテゴリ名そのものを渡す。URL エンコードは Astro が自動で行う
 * - 日本語カテゴリ（例: "技術"）もそのまま `params` に渡せる
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostListItem from "../../components/PostListItem.astro";
import Pagination from "../../components/Pagination.astro";
import { listAllCategories, listPostsByCategory } from "../../lib/queries";
import { paginate } from "../../lib/policies";

export async function getStaticPaths() {
  const categories = await listAllCategories();
  return categories.map((cat) => ({
    params: { category: cat.name },
    props: { category: cat.name },
  }));
}

const { category } = Astro.props;
const posts = await listPostsByCategory(category);
const pageInfo = paginate(posts, 1);

const basePath = `/categories/${category}`;
const canonical = new URL(`${basePath}/`, Astro.site);
const nextUrl = pageInfo.hasNext
  ? new URL(`${basePath}/page/2/`, Astro.site)
  : undefined;
---

<BaseLayout
  title={`Category: ${category}`}
  description={`"${category}" カテゴリの記事一覧`}
  canonical={canonical}
  next={nextUrl}
>
  <section class="bg-bg-secondary py-10 border-b border-border">
    <div class="container-wide">
      <p class="text-sm text-text-muted mb-1">
        <a href="/categories/" class="text-accent underline hover:no-underline">Categories</a>
      </p>
      <h1 class="text-3xl font-bold mb-2">{category}</h1>
      <p class="text-sm text-text-secondary">{pageInfo.total} 件の記事</p>
    </div>
  </section>

  <section class="container-wide py-10">
    {
      pageInfo.total === 0 ? (
        <p class="text-text-muted">このカテゴリの記事はまだありません。</p>
      ) : (
        <div class="max-w-[45rem]">
          {pageInfo.items.map((post) => (
            <PostListItem post={post} headingLevel={2} showTags />
          ))}
        </div>
      )
    }

    <Pagination
      currentPage={pageInfo.page}
      totalPages={pageInfo.totalPages}
      basePath={basePath}
    />
  </section>
</BaseLayout>
