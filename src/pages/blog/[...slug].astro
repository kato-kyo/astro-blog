---
/**
 * 記事詳細（F-03）。ToC（F-18）・読了時間（F-19）・関連記事（F-20）を提供する。
 *
 * ルール:
 * - `astro:content` は queries/ 経由でのみ使用する（lib-architecture.md）
 * - render() のみ astro:content から直接 import（CollectionEntry を Astro が消費するため）
 */
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostListItem from "../../components/PostListItem.astro";
import ToC, { type TocHeading } from "../../components/ToC";
import { estimateReadingTime, findRelatedPosts } from "../../lib/policies";
import {
  getAuthorById,
  listPublishedEntries,
  listPublishedPosts,
  toPostMeta,
} from "../../lib/queries";
import { isDev } from "../../lib/env";
import { entryIdToSlug } from "../../lib/domain";

export async function getStaticPaths() {
  const entries = await listPublishedEntries();
  return entries.map((entry) => ({
    params: { slug: entryIdToSlug(entry.id) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const meta = toPostMeta(entry);
const readingTime = estimateReadingTime(entry.body ?? "");

// 関連記事: 公開記事全体から target を渡してアルゴリズムに委ねる（F-20）
const allPosts = await listPublishedPosts();
const related = findRelatedPosts(meta, allPosts);

// OGP `article:author` 用の著者名解決。未登録の場合は id をフォールバックとして渡す。
const authorEntry = await getAuthorById(meta.author);
const authorName = authorEntry?.name ?? meta.author;

// ToC 用に depth/slug/text の最小形に変換（React 側に渡す props を Astro API から分離）
const tocHeadings: TocHeading[] = headings.map((h) => ({
  depth: h.depth,
  slug: h.slug,
  text: h.text,
}));

// dev では draft も一覧に出るので、バッジ表示は draft かつ dev のみ。
// prod では queries 側で draft が除外されているため到達しない。
const showDraftBadge = isDev && meta.draft;
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  type="article"
  publishedAt={meta.publishedAt}
  updatedAt={meta.updatedAt}
  author={authorName}
>
  <article class="content-prose py-10">
    <header class="mb-8 pb-4 border-b border-border">
      <h1 class="text-3xl font-bold leading-snug mb-3">{meta.title}</h1>
      <div class="flex gap-3 flex-wrap text-xs text-text-muted">
        <time datetime={meta.publishedAt.toISOString()}>
          {meta.publishedAt.toLocaleDateString("ja-JP")}
        </time>
        <span>|</span>
        <span>読了 {readingTime} 分</span>
        <span>|</span>
        <a href={`/categories/${meta.category}/`}>{meta.category}</a>
        {
          showDraftBadge && (
            <span class="px-2 py-0.5 bg-draft-badge text-white rounded-sm font-semibold uppercase text-[0.6875rem]">
              Draft
            </span>
          )
        }
      </div>
    </header>

    <ToC headings={tocHeadings} client:idle />

    <div class="prose max-w-none">
      <Content />
    </div>

    {
      related.length > 0 && (
        <aside class="mt-12 pt-6 border-t border-border" aria-labelledby="related-heading">
          <h2 id="related-heading" class="text-xl font-bold mb-2">関連記事</h2>
          <div>
            {related.map((post) => (
              <PostListItem post={post} headingLevel={3} showTags={true} />
            ))}
          </div>
        </aside>
      )
    }
  </article>
</BaseLayout>
