---
/**
 * ベースレイアウト。全ページ共通の HTML 構造・ヘッダー・フッター・メタタグを提供する。
 *
 * 参照:
 * - docs/design.md §4.1 (共通レイアウト)
 * - docs/design.md §6 (ダークモード FOUC 対策)
 */
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../config/site";

type Props = {
  title: string;
  description?: string;
};

const { title, description = SITE.description } = Astro.props;
const pageTitle = title === SITE.title ? title : `${title} | ${SITE.title}`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    {/* FOUC 防止: design.md §6.1 準拠。localStorage/matchMedia を単一 try で包む */}
    <script is:inline>
      (function () {
        let isDark = false;
        try {
          const stored = localStorage.getItem("theme");
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          isDark = stored === "dark" || (!stored && prefersDark);
        } catch (_e) {
          /* localStorage / matchMedia が使えない環境では light を既定とする */
        }
        if (isDark) document.documentElement.classList.add("dark");
        document.documentElement.style.colorScheme = isDark ? "dark" : "light";
      })();
    </script>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:bg-accent focus:text-white focus:px-3 focus:py-2 focus:rounded"
    >
      メインコンテンツへスキップ
    </a>
    <Header />
    <main id="main" class="min-h-[60vh]">
      <slot />
    </main>
    <Footer />
  </body>
</html>
