---
/**
 * ベースレイアウト。全ページ共通の HTML 構造・ヘッダー・フッター・メタタグを提供する。
 *
 * 参照:
 * - docs/design.md §4.1 (共通レイアウト)
 * - docs/design.md §6 (ダークモード FOUC 対策)
 */
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../config/site";

type Props = {
  title: string;
  description?: string;
  /** `<link rel="canonical">` の URL。ページネーション等、正規 URL を明示したい場合に指定 */
  canonical?: string | URL;
  /** `<link rel="prev">` の URL（ページネーション） */
  prev?: string | URL;
  /** `<link rel="next">` の URL（ページネーション） */
  next?: string | URL;
  /**
   * OGP 画像 URL（F-24）。
   * 現状サイトデフォルト画像は未整備のため、未指定なら `og:image` は出力しない。
   * 将来サイトデフォルト画像を用意した場合はここで補完する。
   */
  image?: string | URL;
  /** OGP タイプ（F-24）。記事ページでは `article` を指定する */
  type?: "website" | "article";
  /** `article:published_time`（記事ページのみ） */
  publishedAt?: Date;
  /** `article:modified_time`（記事ページのみ） */
  updatedAt?: Date;
  /** `article:author`（記事ページのみ。著者名） */
  author?: string;
};

const {
  title,
  description = SITE.description,
  canonical,
  prev,
  next,
  image,
  type = "website",
  publishedAt,
  updatedAt,
  author,
} = Astro.props;
const pageTitle = title === SITE.title ? title : `${title} | ${SITE.title}`;
const canonicalHref = canonical ? canonical.toString() : undefined;
const prevHref = prev ? prev.toString() : undefined;
const nextHref = next ? next.toString() : undefined;

// OGP の URL は canonical を最優先し、未指定なら現在の request URL を使う。
// Astro.site は astro.config.ts の `site` を参照（本番 URL / プレビュー URL を環境で切替）
const ogUrl = canonicalHref ?? new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const ogImage = image ? image.toString() : undefined;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {canonicalHref && <link rel="canonical" href={canonicalHref} />}
    {prevHref && <link rel="prev" href={prevHref} />}
    {nextHref && <link rel="next" href={nextHref} />}

    {/* Open Graph Protocol（F-24） */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:locale" content="ja_JP" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    {/* 記事ページのみ出力する article:* メタタグ */}
    {type === "article" && publishedAt && (
      <meta property="article:published_time" content={publishedAt.toISOString()} />
    )}
    {type === "article" && updatedAt && (
      <meta property="article:modified_time" content={updatedAt.toISOString()} />
    )}
    {type === "article" && author && <meta property="article:author" content={author} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    {/* FOUC 防止: design.md §6.1 準拠。localStorage/matchMedia を単一 try で包む */}
    <script is:inline>
      (function () {
        let isDark = false;
        try {
          const stored = localStorage.getItem("theme");
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          isDark = stored === "dark" || (!stored && prefersDark);
        } catch (_e) {
          /* localStorage / matchMedia が使えない環境では light を既定とする */
        }
        if (isDark) document.documentElement.classList.add("dark");
        document.documentElement.style.colorScheme = isDark ? "dark" : "light";
      })();
    </script>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:bg-accent focus:text-white focus:px-3 focus:py-2 focus:rounded"
    >
      メインコンテンツへスキップ
    </a>
    <Header />
    <main id="main" class="min-h-[60vh]">
      <slot />
    </main>
    <Footer />
  </body>
</html>
