---
/**
 * 検索モーダルを開くヘッダー内トリガー（F-21 / T4.1）。
 *
 * - Pagefind の JS を含まない軽量な Astro コンポーネント。クリックで `Search` React island に
 *   `CustomEvent('astro-blog:open-search')` を送り、そちらでモーダル状態を持つ。
 * - `aria-controls` は `<Search />` 内部の dialog id と一致させる。
 * - `/` キーや `Cmd+K` でもモーダルが開くが、本ボタンは視覚的な発見性と a11y のために必要。
 */
---

<button
  type="button"
  id="search-trigger"
  aria-label="検索"
  aria-controls="search-modal"
  class="inline-flex items-center justify-center w-9 h-9 rounded-sm text-header-text opacity-90 hover:opacity-100 hover:bg-bg-secondary transition-colors"
  title="検索 (/)"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="11" cy="11" r="8"></circle>
    <path d="m21 21-4.3-4.3"></path>
  </svg>
</button>

<script is:inline>
  (function () {
    const btn = document.getElementById("search-trigger");
    if (!btn) return;
    btn.addEventListener("click", () => {
      // Search.tsx の useEffect で listen している内部イベント
      window.dispatchEvent(new CustomEvent("astro-blog:open-search"));
    });
  })();
</script>
