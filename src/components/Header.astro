---
/**
 * サイトヘッダー（GP 風: static・ソリッド背景・nav padding 10px 20px・font-size 15px）。
 *
 * - ナビ右端に SearchTrigger + Search（React island, `client:idle`）+ ThemeToggle（`client:load`）を配置する。
 *   FOUC 防止スクリプト（BaseLayout.astro §6.1）が走った直後から操作可能にしたいため
 *   ThemeToggle は `client:load` 必須（`client:idle` / `client:visible` は NG）。
 *   Search は Pagefind JS の遅延読込が前提のため `client:idle` で十分。
 */
import { getSite } from "../lib/queries";
import { MAIN_NAV } from "../config/nav";
import ThemeToggle from "./ThemeToggle";
import Search from "./Search";
import SearchTrigger from "./SearchTrigger.astro";

const site = await getSite();
---

<header class="bg-header-bg text-header-text border-b border-header-border">
  <div class="container-wide flex flex-wrap items-center justify-between gap-y-2 min-h-[64px] py-2">
    <a
      href="/"
      class="text-[1.1rem] font-bold tracking-tight text-header-text"
      aria-label={`${site.title} トップへ`}
    >
      {site.authorJa}
    </a>
    <nav aria-label="主要ナビゲーション" class="flex items-center flex-wrap gap-y-1 max-w-full">
      <ul class="flex flex-wrap gap-x-1 gap-y-1 m-0 p-0 list-none items-center">
        {
          MAIN_NAV.map((item) => (
            <li>
              <a
                href={item.href}
                class="block px-3 md:px-5 py-2 text-[15px] font-normal text-header-text opacity-90 hover:opacity-100"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="ml-2 flex items-center gap-1">
        <SearchTrigger />
        <ThemeToggle client:load />
      </div>
    </nav>
  </div>
  {/* 検索モーダル本体（Pagefind JS は初回オープン時に遅延読込） */}
  <Search client:idle />
</header>
