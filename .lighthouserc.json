{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/",
        "http://localhost/blog/",
        "http://localhost/blog/hello-world/",
        "http://localhost/about/"
      ],
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", {"minScore": 0.9, "aggregationMethod": "median"}],
        "categories:accessibility": ["warn", {"minScore": 0.9, "aggregationMethod": "median"}],
        "categories:best-practices": ["error", {"minScore": 0.9, "aggregationMethod": "median"}],
        "categories:seo": ["error", {"minScore": 0.9, "aggregationMethod": "median"}]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
