{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:astro.build)",
      "WebFetch(domain:docs.astro.build)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:vitejs.dev)",
      "WebFetch(domain:vitest.dev)",
      "WebFetch(domain:react.dev)",
      "Bash(node --version)",
      "Bash(pnpm --version)",
      "Bash(npm view *)",
      "Bash(pnpm install *)",
      "Bash(pnpm add *)",
      "Bash(pnpm remove *)",
      "Bash(pnpm dev *)",
      "Bash(pnpm build *)",
      "Bash(pnpm preview *)",
      "Bash(pnpm test *)",
      "Bash(pnpm check *)",
      "Bash(pnpm run *)",
      "Bash(pnpm init *)",
      "Bash(pnpm approve-builds *)",
      "Bash(npx astro *)",
      "Bash(npx vitest *)",
      "Bash(npx tsc *)",
      "Bash(mkdir -p *)",
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git switch *)",
      "Bash(git checkout -b *)",
      "Bash(git merge *)",
      "Bash(git push *)",
      "Bash(git submodule *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "mcp__astro-docs__*",
      "mcp__playwright__*",
      "Skill(git:commit)",
      "Skill(git:commit:*)",
      "Skill(git:commit-msg)",
      "Skill(git:pull-req)",
      "Skill(git:pull-req:*)",
      "Skill(fix-error)",
      "Skill(fix-lint)",
      "Skill(simplify)",
      "Skill(frontend-design)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": ["codex"],
    "enableWeakerNetworkIsolation": true,
    "filesystem": {
      "allowWrite": [
        "~/Library/pnpm/store/**",
        "~/.npm/**",
        "~/.cache/codex/**",
        "~/.codex/**"
      ]
    },
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": [
        "registry.npmjs.org",
        "*.npmjs.org",
        "fonts.googleapis.com",
        "fonts.gstatic.com",
        "mcp.docs.astro.build",
        "github.com",
        "api.github.com",
        "codeload.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "api.openai.com",
        "*.openai.com"
      ]
    }
  }
}
